{
  "name": "openclaw-plugin-a2ex",
  "version": "0.1.3",
  "type": "module",
  "description": "OpenClaw plugin for autonomous AI trading — Polymarket, Hyperliquid, and more",
  "main": "./dist/index.js",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist/",
    "openclaw.plugin.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/forrestkim-iotrust/a2ex.git",
    "directory": "plugin"
  },
  "homepage": "https://github.com/forrestkim-iotrust/a2ex",
